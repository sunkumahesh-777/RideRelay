PORT=4000
JWT_SECRET=replace-with-a-long-random-secret

# Recommended for the persistent RideRelay Node backend:
# Supabase Dashboard -> Connect -> Session pooler -> URI
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

PGSSL=require
DB_READ_MODE=normalized
